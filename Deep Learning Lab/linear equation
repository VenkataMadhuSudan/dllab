import tensorflow as tf, numpy as np

m = tf.keras.Sequential([tf.keras.layers.Dense(1, input_shape=[1])])
m.compile('sgd','mse')
# Training data y=2x-1
x = np.array([-1,0,1,2,3,4], float)
y = np.array([-3,-1,1,3,5,7], float)

m.fit(x, y, epochs=500, verbose=1)
print("Predicted y:", m.predict(np.array([10.0])))
